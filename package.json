{
  "name": "pi-powerline",
  "version": "1.0.0",
  "description": "pi-coding-agent extension: unified powerline footer and status bar",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "src/**/*.ts",
    "!src/__tests__/**",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint:fix": "eslint --fix src/"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "harms-haus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harms-haus/pi-powerline.git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
